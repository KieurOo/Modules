return function(Window, player, SellingTab, sellFuncs)
    local items = sellFuncs.items
    local maxLimits = sellFuncs.maxLimits
    local nonSellable = sellFuncs.nonSellable
    local itemOptions = sellFuncs.itemOptions
    local worthlessItems = sellFuncs.worthlessItems
    local updateItems = sellFuncs.updateItems
    local sellItem = sellFuncs.sellItem
    local sellAll = sellFuncs.sellAll
    local sellAllSelected = sellFuncs.sellAllSelected
    local sellAllWorthless = sellFuncs.sellAllWorthless
    local sellInventory = sellFuncs.sellInventory
    local checkAndSellMax = sellFuncs.checkAndSellMax

    local autoSellMax = true
    local autoSellSelected = false
    local selectedAutoSellItems = {}
    local selectedSellAllItems = {}
    local lastAutoSellNotify = {}

    player.Backpack.ChildAdded:Connect(function(item)
        if autoSellMax then
            checkAndSellMax()
        end
        if autoSellSelected and table.find(selectedAutoSellItems, item.Name) then
            wait(0.2)
            local now = tick()
            local last = lastAutoSellNotify[item.Name] or 0
            if now - last >= 0.5 then
                if sellItem(item) then
                    Window:Notify("Auto Sell", "Auto sold " .. item.Name .. " on pickup.", 3)
                    lastAutoSellNotify[item.Name] = now
                end
            end
        end
    end)

    player.CharacterAdded:Connect(function(char)
        char.ChildAdded:Connect(function(item)
            if autoSellMax then
                checkAndSellMax()
            end
            if autoSellSelected and table.find(selectedAutoSellItems, item.Name) then
                wait(0.2)
                local now = tick()
                local last = lastAutoSellNotify[item.Name] or 0
                if now - last >= 0.5 then
                    if sellItem(item) then
                        Window:Notify("Auto Sell", "Auto sold " .. item.Name .. " on pickup.", 3)
                        lastAutoSellNotify[item.Name] = now
                    end
                end
            end
        end)
    end)

    local SellLeft = SellingTab:Section("Auto Sell", "Left", "shopping-cart")
    local SellRight = SellingTab:Section("Manual Sell", "Right", "hand-coins")

    SellLeft:Toggle("Auto Sell on Max", true, function(state)
        autoSellMax = state
        if autoSellMax then
            Window:Notify("Selling", "Auto Sell on Max enabled.", 3)
            checkAndSellMax()
        else
            Window:Notify("Selling", "Auto Sell on Max disabled.", 3)
        end
    end)

    SellLeft:MultiDropdown("Auto Sell Items (on Pickup)", itemOptions, {}, function(selectedList, changedItem)
        selectedAutoSellItems = selectedList
    end, true)

    SellLeft:Toggle("Auto Sell Selected on Pickup", false, function(state)
        autoSellSelected = state
        if autoSellSelected then
            Window:Notify("Selling", "Auto Sell Selected enabled.", 3)
        else
            Window:Notify("Selling", "Auto Sell Selected disabled.", 3)
        end
    end)

    SellLeft:MultiDropdown("Select Items to Sell All Now", itemOptions, {}, function(selectedList, changedItem)
        selectedSellAllItems = selectedList
    end, true)

    SellLeft:Button("Sell All Selected Now", function()
        sellAllSelected(selectedSellAllItems)
    end)

    local autoSellAllSelectedLoop = false
    local autoSellInterval = 3

    SellLeft:Slider("Auto Sell Interval (minutes)", false, 1, 10, 3, function(value)
        autoSellInterval = value
    end)

    SellLeft:Toggle("Auto Sell All Selected Loop", false, function(state)
        autoSellAllSelectedLoop = state
        if state then
            Window:Notify("Selling", "Auto Sell enabled: Every " .. autoSellInterval .. " minute(s)", 3)
            spawn(function()
                while autoSellAllSelectedLoop do
                    wait(autoSellInterval * 60)
                    if autoSellAllSelectedLoop and #selectedSellAllItems > 0 then
                        sellAllSelected(selectedSellAllItems)
                    end
                end
            end)
        else
            Window:Notify("Selling", "Auto Sell All Selected disabled.", 3)
        end
    end)

    SellRight:Button("Sell All Worthless Items", function()
        sellAllWorthless()
    end)

    SellRight:Button("Sell Inventory", function()
        sellInventory()
    end)
end
