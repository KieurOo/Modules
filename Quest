	local function isHandheldMethod()
		local m = FarmConfig.FarmingMethod
		if type(m) == "table" then m = m[1] end
		if m == "Handheld/Fist" then
			return true
		end
		if m == "Auto" or m == "Auto (Detect)" then
			return STAND_KEEPALIVE_EXCLUDED[Players.LocalPlayer.PlayerStats.Stand.Value] == true
		end
		return false
	end

	function FarmUtil.EquipStand()
		local char = FarmUtil.GetCharacter()
		if not char then return false end
		if isHandheldMethod() then
			if char:FindFirstChildWhichIsA("Tool") then
				return true
			end
			local rf = char:FindFirstChild("RemoteFunction")
			if rf then
				pcall(function()
					rf:InvokeServer("ToggleStand", "Toggle")
				end)
				task.wait(0.25)
				return char:FindFirstChildWhichIsA("Tool") ~= nil
			end
			return true
		end
		local ss = char:FindFirstChild("SummonedStand")
		if ss and ss.Value then
			return true
		end
		local rf = char:FindFirstChild("RemoteFunction")
		if rf then
			pcall(function()
				rf:InvokeServer("ToggleStand", "Toggle")
			end)
			task.wait(0.25)
			ss = char:FindFirstChild("SummonedStand")
			return ss and ss.Value
		end
		return false
	end

	function FarmUtil.UseMove(move)
		local char = FarmUtil.GetCharacter()
		if char and char:FindFirstChild("RemoteEvent") then
			pcall(function()
				char.RemoteEvent:FireServer("Attack", move)
			end)
		end
	end

	function FarmUtil.CountItem(itemName)
		local count = 0
		for _, v in pairs(Players.LocalPlayer.Backpack:GetChildren()) do
			if v.Name == itemName then
				count = count + 1
			end
		end
		local char = FarmUtil.GetCharacter()
		if char then
			local tool = char:FindFirstChildWhichIsA("Tool")
			if tool and tool.Name == itemName then
				count = count + 1
			end
		end
		return count
	end

	local function clickThroughDialogue()
		local plr = game:GetService("Players").LocalPlayer
		local dialogueGui = plr.PlayerGui:FindFirstChild("DialogueGui")
		local startTime = tick()
		while dialogueGui and dialogueGui.Parent and tick() - startTime < 5 do
			pcall(function()
				local frame = dialogueGui:FindFirstChild("Frame")
				if not frame then return end
				local clickContinue = frame:FindFirstChild("ClickContinue")
				if clickContinue then
					for _, conn in pairs(getconnections(clickContinue.MouseButton1Click)) do
						conn:Fire()
					end
				end
				local options = frame:FindFirstChild("Options")
				if options then
					local option1 = options:FindFirstChild("Option1")
					if option1 then
						local textButton = option1:FindFirstChild("TextButton")
						if textButton then
							for _, conn in pairs(getconnections(textButton.MouseButton1Click)) do
								conn:Fire()
							end
						end
					end
				end
			end)
			task.wait(0.1)
			dialogueGui = plr.PlayerGui:FindFirstChild("DialogueGui")
		end
	end

	local function GetQuest(NPC)
		if not NPC then return false end
		local DialogueNameObj = NPC:FindFirstChild("Dialogue")
		local Character = GetCharacter()
		if not DialogueNameObj or not Character or not Character:FindFirstChild("RemoteEvent") then
			return false
		end
		local DialogueName = DialogueNameObj.Value
		local Event = Character:FindFirstChild("RemoteEvent")
		local plr = game:GetService("Players").LocalPlayer

		if NPC.Name == "DIO [Lvl. 35+]" then
			pcall(function()
				Event:FireServer("PromptTriggered", game:GetService("ReplicatedStorage"):WaitForChild("Dialogue"):WaitForChild("DIO"))
			end)
			local dlgStart = tick()
			repeat
				task.wait(0.1)
			until plr.PlayerGui:FindFirstChild("DialogueGui") or tick() - dlgStart > 3
			local dioDlgStart = tick()
			while plr.PlayerGui:FindFirstChild("DialogueGui") and tick() - dioDlgStart < 6 do
				pcall(function()
					local dg = plr.PlayerGui.DialogueGui
					local frame = dg:FindFirstChild("Frame")
					if not frame then return end
					local cc = frame:FindFirstChild("ClickContinue")
					if cc then
						for _, conn in pairs(getconnections(cc.MouseButton1Click)) do
							conn:Fire()
						end
					end
					local opts = frame:FindFirstChild("Options")
					if opts then
						for i = 1, 4 do
							local opt = opts:FindFirstChild("Option" .. tostring(i))
							if opt then
								local tb = opt:FindFirstChild("TextButton")
								if tb then
									for _, conn in pairs(getconnections(tb.MouseButton1Click)) do
										conn:Fire()
									end
								end
							end
						end
					end
				end)
				task.wait(0.15)
			end
			local dioName = "DIO"
			for dNum = 1, 8 do
				for oNum = 1, 3 do
					pcall(function()
						Event:FireServer("EndDialogue", {
							["NPC"] = dioName,
							["Option"] = "Option" .. tostring(oNum),
							["Dialogue"] = "Dialogue" .. tostring(dNum)
						})
					end)
				end
			end
			getgenv().CompletedQuest = false
			FarmState.CompletedQuest = false
			return true
		end

		pcall(function()
			Event:FireServer("DialogueInteracted", {
				["DialogueName"] = DialogueName,
				["Speaker"] = NPC.Name
			})
		end)
		for dialogueNum = 1, 8 do
			for optionNum = 1, 3 do
				pcall(function()
					Event:FireServer("EndDialogue", {
						["NPC"] = DialogueName,
						["Option"] = "Option" .. tostring(optionNum),
						["Dialogue"] = "Dialogue" .. tostring(dialogueNum)
					})
				end)
			end
		end
		local specialPatterns = {
			{Dialogue = "Dialogue2", Option = "Option1"},
			{Dialogue = "Dialogue4", Option = "Option1"},
			{Dialogue = "Dialogue6", Option = "Option1"},
			{Dialogue = "Dialogue2", Option = "Option2"},
			{Dialogue = "Dialogue3", Option = "Option1"},
			{Dialogue = "Dialogue5", Option = "Option1"},
		}
		for _, pattern in ipairs(specialPatterns) do
			pcall(function()
				Event:FireServer("EndDialogue", {
					["NPC"] = DialogueName,
					["Option"] = pattern.Option,
					["Dialogue"] = pattern.Dialogue
				})
			end)
		end
		getgenv().CompletedQuest = false
		FarmState.CompletedQuest = false
		return true
	end

