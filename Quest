	local function ParseQuests()
		local parsed = {}
		local seen = {}
		local dialogues = workspace:FindFirstChild("Dialogues")
		if dialogues then
			for _, v in pairs(dialogues:GetChildren()) do
				local name = v.Name
				local lower = name:lower()
				local isQuest = (lower:find("lvl") or name == "Jotaro")
					and not lower:find("darius")
					and not lower:find("pucci")
					and not lower:find("kars")
				if isQuest and not seen[name] then
					seen[name] = true
					table.insert(parsed, name)
				end
			end
		end
		for questName, _ in pairs(QuestInfo) do
			if dialogues and dialogues:FindFirstChild(questName) and not seen[questName] then
				seen[questName] = true
				table.insert(parsed, questName)
			end
		end
		table.sort(parsed)
		return parsed
	end

	local ParsedQuests = ParseQuests()
	if workspace:FindFirstChild("Dialogues") then
		workspace.Dialogues.ChildAdded:Connect(function(child)
			if not child then return end
			local name = child.Name
			local lower = name:lower()
			local isQuest = (lower:find("lvl") or name == "Jotaro")
				and not lower:find("darius")
				and not lower:find("pucci")
				and not lower:find("kars")
			if isQuest then
				for _, existing in ipairs(ParsedQuests) do
					if existing == name then return end
				end
				table.insert(ParsedQuests, name)
				table.sort(ParsedQuests)
				pcall(function()
					if QuestDropdown and QuestDropdown.Refresh then
						QuestDropdown:Refresh(ParsedQuests)
					elseif QuestDropdown and QuestDropdown.Set then
						QuestDropdown:Set(ParsedQuests[1] or "No quests available")
					end
				end)
			end
		end)
	end

	local function GetBestQuest()
		local playerLevel = Players.LocalPlayer.PlayerStats.Level.Value
		local bestQuest, highestReq = nil, 0
		for _, questName in pairs(ParsedQuests) do
			if questName ~= "Auto (Best for Level)" then
				local levelReq = tonumber(questName:match("%d+"))
				if levelReq and levelReq <= playerLevel and levelReq >= highestReq then
					highestReq = levelReq
					bestQuest = questName
				end
			end
		end
		return bestQuest
	end

	local function GetBestQuestForLevel(currentLevel)
		local bestQuest = nil
		local highestReq = -1
		for _, questName in pairs(ParsedQuests) do
			if questName ~= "No quests available" then
				local levelReq = tonumber(questName:match("(%d+)"))
				if levelReq and levelReq <= currentLevel and levelReq > highestReq then
					highestReq = levelReq
					bestQuest = questName
				end
			end
		end
		return bestQuest
	end

	local function GetQuestLevelRequirement(questName)
		if not questName then return 0 end
		local levelReq = tonumber(questName:match("(%d+)"))
		return levelReq or 0
	end

	local function GetPlayerLevel()
		local player = GetPlayer()
		if player and player:FindFirstChild("PlayerStats") and player.PlayerStats:FindFirstChild("Level") then
			return player.PlayerStats.Level.Value
		end
		return 0
	end

	local function GetQuestState()
		local player = GetPlayer()
		if not player or not player:FindFirstChild("PlayerStats") then
			return "none", nil, 0, 0
		end
		local currentQuest = player.PlayerStats:FindFirstChild("CurrentQuest")
		local questProgress = player.PlayerStats:FindFirstChild("QuestProgress")
		local questMax = player.PlayerStats:FindFirstChild("QuestMaxProgress")
		if currentQuest and currentQuest.Value ~= "" and questProgress and questMax then
			local progress = questProgress.Value or 0
			local maxProgress = questMax.Value or 0
			if maxProgress > 0 and progress >= maxProgress then
				return "complete", currentQuest.Value, progress, maxProgress
			end
			return "active", currentQuest.Value, progress, maxProgress
		end
		return "none", nil, 0, 0
	end

	local function HasActiveQuest()
		local state = GetQuestState()
		return state == "active"
	end

	local function IsQuestComplete()
		local state = GetQuestState()
		return state == "complete"
	end

	local function GetCurrentQuestDisplayName()
		local player = GetPlayer()
		if player and player:FindFirstChild("PlayerStats") then
			local currentQuest = player.PlayerStats:FindFirstChild("CurrentQuest")
			if currentQuest and currentQuest.Value ~= "" then
				return currentQuest.Value
			end
		end
		if getgenv().SelectedQuest and getgenv().SelectedQuest ~= "" and getgenv().SelectedQuest ~= "No quests available" then
			return getgenv().SelectedQuest
		end
		return nil
	end

	local function UpdateQuestStatusLabel()
		local labelText = "No active quest"
		local player = GetPlayer()
		if not player or not player:FindFirstChild("PlayerStats") then
			pcall(function()
				if _G.QuestCurrentQuestLabelObj then
					if _G.QuestCurrentQuestLabelObj.Set then
						_G.QuestCurrentQuestLabelObj:Set(labelText)
					elseif _G.QuestCurrentQuestLabelObj.Text then
						_G.QuestCurrentQuestLabelObj.Text = labelText
					end
				end
			end)
			return
		end
		local currentQuest = player.PlayerStats:FindFirstChild("CurrentQuest")
		if not currentQuest or currentQuest.Value == "" then
			pcall(function()
				if _G.QuestCurrentQuestLabelObj then
					if _G.QuestCurrentQuestLabelObj.Set then
						_G.QuestCurrentQuestLabelObj:Set(labelText)
					elseif _G.QuestCurrentQuestLabelObj.Text then
						_G.QuestCurrentQuestLabelObj.Text = labelText
					end
				end
			end)
			return
		end
		local questName = currentQuest.Value
		local questProgress = player.PlayerStats:FindFirstChild("QuestProgress")
		local questMax = player.PlayerStats:FindFirstChild("QuestMaxProgress")
		local progress = 0
		local maxProgress = 0
		if questProgress then progress = tonumber(questProgress.Value) or 0 end
		if questMax then maxProgress = tonumber(questMax.Value) or 0 end
		if maxProgress > 0 then
			local remaining = math.max(0, maxProgress - progress)
			if remaining > 0 then
				labelText = questName .. " | " .. tostring(progress) .. "/" .. tostring(maxProgress) .. " (" .. tostring(remaining) .. " left)"
			else
				labelText = questName .. " | " .. tostring(progress) .. "/" .. tostring(maxProgress) .. " | Finished"
			end
		else
			labelText = questName .. " | Progress: " .. tostring(progress)
		end
		pcall(function()
			if _G.QuestCurrentQuestLabelObj then
				if _G.QuestCurrentQuestLabelObj.Set then
					_G.QuestCurrentQuestLabelObj:Set(labelText)
				elseif _G.QuestCurrentQuestLabelObj.Text then
					_G.QuestCurrentQuestLabelObj.Text = labelText
				end
			end
		end)
	end

	local function IsPlayerReady()
		local player = GetPlayer()
		if not player then return false end
		local character = player.Character
		if not character then return false end
		local humanoid = character:FindFirstChildWhichIsA("Humanoid")
		if not humanoid then return false end
		if humanoid.Health <= 0 then return false end
		if not character:FindFirstChild("HumanoidRootPart") then return false end
		if not character.PrimaryPart then return false end
		return true
	end

	local function WaitForCharacter(timeout)
		timeout = timeout or 10
		local player = GetPlayer()
		if not player then return false end
		local start = tick()
		while tick() - start < timeout do
			if player.Character then
				local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
				if humanoid and humanoid.Health > 0 then
					return true
				end
			end
			task.wait(0.1)
		end
		return false
	end

