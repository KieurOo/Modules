QuestLeft:Toggle("Enable Quest Farm", false, function(value)
    if value then
        if getgenv().normalFarmOn or getgenv().afkFarmOn or getgenv().afkUnderneathFarmOn or getgenv().safePlaceFarmOn then
            Window:Notify("Quest", "Item Farm is running! Disable it first.", 3)
            return
        end
        if ribFarmRunning then
            Window:Notify("Quest", "Rib Farm is running! Disable it first.", 3)
            return
        end
        if getgenv().autoPrestigeEnabled or getgenv().autoPrestigeBusy then
            Window:Notify("Quest", "Auto Storyline is running! Disable it first.", 3)
            return
        end
        if getgenv().NPCFarmEnabled then
            Window:Notify("Quest", "NPC Farm is running! Disable it first.", 3)
            return
        end
        if standFarmEnabled or standFarmBusy then
            standFarmEnabled = false
            standFarmBusy = false
            Window:Notify("Quest", "Auto-stopped Stand Farm to prevent conflict.", 3)
            task.wait(0.5)
        end
    end
    
    getgenv().QuestFarmEnabled = value
    UpdateQuestStatusLabel()
    
        if value then
            task.spawn(function()
                Window:Notify("Quest", "Quest Farm started!", 3)
            end)
            enableNoclip()

            local player = GetPlayer()
            if player and player:FindFirstChild("PlayerStats") then
                local currentQuest = player.PlayerStats:FindFirstChild("CurrentQuest")
                local questProgress = player.PlayerStats:FindFirstChild("QuestProgress")
                local questMax = player.PlayerStats:FindFirstChild("QuestMaxProgress")

                if currentQuest and currentQuest.Value ~= "" and questProgress and questMax then
                    getgenv().SelectedQuest = currentQuest.Value
                    if questProgress.Value >= questMax.Value then
                        getgenv().CompletedQuest = true
                        task.spawn(function()
                            Window:Notify("Quest", "Quest complete! Will turn in and get new one.", 3)
                        end)
                    else
                        getgenv().CompletedQuest = false
                        task.spawn(function()
                            Window:Notify("Quest", "Resuming quest: " .. currentQuest.Value, 3)
                        end)
                    end
                else
                    getgenv().CompletedQuest = true
                end
            end
        task.spawn(function()
            while getgenv().QuestFarmEnabled do
                if not IsPlayerReady() then
                    disableNoclip()
                    repeat task.wait(0.5) until IsPlayerReady() or not getgenv().QuestFarmEnabled
                    if not getgenv().QuestFarmEnabled then break end
                    task.wait(2)
                    if not getgenv().QuestFarmEnabled then break end
                    enableNoclip()
                    if getgenv().QuestMethod == "With Stand" and IsPlayerReady() then
                        EquipStand()
                    end
                    continue
                end
                
                local playerLevel = GetPlayerLevel()
                UpdateQuestStatusLabel()

                if getgenv().AutoSelectBestQuest then
                    local bestQuest = GetBestQuestForLevel(playerLevel)
                    if bestQuest and bestQuest ~= getgenv().SelectedQuest then
                        getgenv().PreviousQuest = getgenv().SelectedQuest
                        getgenv().SelectedQuest = bestQuest
                        getgenv().CompletedQuest = true
                        pcall(function()
                            if QuestDropdown and QuestDropdown.Set then
                                QuestDropdown:Set(bestQuest)
                            end
                        end)
                        task.spawn(function()
                            Window:Notify("Quest", "Switched to: " .. bestQuest, 3)
                        end)
                    end
                elseif not HasActiveQuest() then
                    if getgenv().SelectedQuest then
                        local selectedLevel = GetQuestLevelRequirement(getgenv().SelectedQuest)
                        if selectedLevel > playerLevel then
                            local bestQuest = GetBestQuestForLevel(playerLevel)
                            if bestQuest then
                                getgenv().SelectedQuest = bestQuest
                                getgenv().CompletedQuest = true
                                task.spawn(function()
                                    Window:Notify("Quest", "Auto-adjusted to: " .. bestQuest, 3)
                                end)
                            end
                        end
                    else
                        local bestQuest = GetBestQuestForLevel(playerLevel)
                        if bestQuest then
                            getgenv().SelectedQuest = bestQuest
                            getgenv().CompletedQuest = true
                            task.spawn(function()
                                Window:Notify("Quest", "Auto-selected: " .. bestQuest, 3)
                            end)
                        end
                    end
                end
                
                if getgenv().QuestMethod == "With Stand" then
                    if playerLevel >= 3 and not HasStand() then
                        getgenv().QuestMethod = "Without Stand"
                        pcall(function()
                            if QuestMethodDropdown and QuestMethodDropdown.Set then
                                QuestMethodDropdown:Set("Without Stand")
                            end
                        end)
                        Window:Notify("Quest", "No stand detected! Auto-switched to Without Stand.", 3)
                    else
                        if IsPlayerReady() then
                            EquipStand()
                        end
                    end
                end
                
                if IsQuestComplete() then
                    getgenv().CompletedQuest = true
                elseif HasActiveQuest() then
                    getgenv().CompletedQuest = false
                end

                if getgenv().CompletedQuest then
                    local questName = getgenv().SelectedQuest
                    if not questName or questName == "" or questName == "No quests available" then
                        local bestQuest = GetBestQuestForLevel(playerLevel)
                        if bestQuest then
                            questName = bestQuest
                            getgenv().SelectedQuest = bestQuest
                        else
                            Window:Notify("Quest", "No available quests found!", 3)
                            task.wait(2)
                            continue
                        end
                    end

                    if getgenv().PreviousQuest and getgenv().PreviousQuest ~= "" then
                        local prevNPC = workspace:FindFirstChild("Dialogues") and workspace.Dialogues:FindFirstChild(getgenv().PreviousQuest)
                        if prevNPC then
                            pcall(function() TurnInQuest(prevNPC) end)
                        end
                        getgenv().PreviousQuest = nil
                    end

                    local questNPC = workspace:FindFirstChild("Dialogues") and workspace.Dialogues:FindFirstChild(questName)

                    if questNPC then
                        pcall(function() TurnInQuest(questNPC) end)
                        pcall(function() GetQuest(questNPC) end)
                        getgenv().CompletedQuest = false
                        task.wait(1.2)
                        continue
                    else
                        Window:Notify("Quest", "Quest NPC not found: " .. tostring(questName), 3)
                        task.wait(1)
                    end
else
                    local questName = getgenv().SelectedQuest
                    local questData = QuestInfo[questName]
                    
                    if questData and questData.Enemy then
                        local enemyName = questData.Enemy
                    local living = workspace:FindFirstChild("Living")
                    
                    if living then
                        local foundAny = false

                        for _, v in pairs(living:GetChildren()) do
                            if not getgenv().QuestFarmEnabled then break end
                            if not IsPlayerReady() then break end
                            if getgenv().CompletedQuest then break end

                            if v.Name == enemyName and v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Health") and v.Health.Value > 0 then
                                foundAny = true
                                pcall(function() KillEnemy(v) end)
                            end
                        end

                        if not foundAny then
                            task.wait(1.5)
                        end
                    end
                    elseif questData and questData.Item then
                        local itemName = questData.Item
                        local requiredAmount = questData.Amount or 1
                        
                        local function CountItems()
                            local current = 0
                            local ply = GetPlayer()
                            if not ply then return 0 end
                            if ply:FindFirstChild("Backpack") then
                                for _, it in pairs(ply.Backpack:GetChildren()) do
                                    if it.Name == itemName then current = current + 1 end
                                end
                            end
                            if ply.Character then
                                for _, it in pairs(ply.Character:GetChildren()) do
                                    if it.Name == itemName then current = current + 1 end
                                end
                            end
                            return current
                        end
                        
                        if CountItems() >= requiredAmount then
                            getgenv().CompletedQuest = true
                            Window:Notify("Quest", "Items collected! Turn in quest.", 3)
                        else
                            local spawns = workspace:FindFirstChild("Item_Spawns") and workspace.Item_Spawns:FindFirstChild("Items")
                            if spawns then
                                for _, v in pairs(spawns:GetChildren()) do
                                    if not getgenv().QuestFarmEnabled then break end
                                    if getgenv().CompletedQuest then break end
                                    local prox = v:FindFirstChild("ProximityPrompt")
                                    if prox and prox.ObjectText == itemName and v:FindFirstChild("PrimaryPart") then
                                        pcall(function()
                                            local HRP = GetHRP()
                                            if HRP and v.PrimaryPart then
                                                local OldCF = HRP.CFrame
                                                HRP.CFrame = v.PrimaryPart.CFrame - Vector3.new(0, 10, 0)
                                                task.wait(math.max(0.05, getgenv().QuestDelay))
                                                fireproximityprompt(prox, 0, true)
                                                task.wait(math.max(0.05, getgenv().QuestDelay))
                                                HRP.CFrame = OldCF
                                            end
                                        end)
                                        task.wait(math.max(0.05, getgenv().QuestDelay))
                                    end
                                end
                            end
                        end
                    else
                        Window:Notify("Quest", "Unknown quest type for: " .. tostring(questName), 3)
                        task.wait(1)
                    end
                end
                
                task.wait(0.01)
            end
            
            disableNoclip()
            Window:Notify("Quest", "Quest Farm stopped!", 3)
        end)
    else
        Window:Notify("Quest", "Quest Farm stopped!", 3)
        getgenv().NoStandNotified = false
        disableNoclip()
    end
end)

