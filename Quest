	local function FarmLoop()
		local lp = Players.LocalPlayer
		local PlayerGui = lp:WaitForChild("PlayerGui")
		local hud = PlayerGui:FindFirstChild("HUD")
		local connection
		if hud then
			connection = hud.ChildAdded:Connect(function(child)
				if child.Name == "QuestCompleted" then
					FarmState.CompletedQuest = true
				end
			end)
		end

		task.spawn(function()
			while FarmState.Active do
				task.wait(3)
				if not FarmState.Active then break end
				if isHandheldMethod() and not STAND_KEEPALIVE_EXCLUDED[Players.LocalPlayer.PlayerStats.Stand.Value] then
					continue
				end
				local char = Players.LocalPlayer.Character
				if char then
					local ss = char:FindFirstChild("SummonedStand")
					if not (ss and ss.Value) then
						pcall(FarmUtil.EquipStand)
					end
				end
			end
		end)

		local masterConn = farmThrottledHeartbeat(function()
			if not FarmState.Active then return end
			local char = Players.LocalPlayer.Character
			if not char then return end
			local hHRP = char:FindFirstChild("HumanoidRootPart")
			if not hHRP then return end

			if isHandheldMethod() then
				local enemy = FarmUtil.CurrentEnemy
				if enemy and enemy.Parent then
					local eHRP = enemy:FindFirstChild("HumanoidRootPart")
					if eHRP then
						hHRP.CFrame = eHRP.CFrame
						hHRP.AssemblyLinearVelocity = Vector3.zero
					end
				end
				return
			end

			local sm = char:FindFirstChild("StandMorph")
			if not sm or not sm.PrimaryPart then
				hHRP.AssemblyLinearVelocity = Vector3.zero
				hHRP.AssemblyAngularVelocity = Vector3.zero
				return
			end

			local enemy = FarmUtil.CurrentEnemy
			if enemy and enemy.Parent then
				local eHRP = enemy:FindFirstChild("HumanoidRootPart")
				if eHRP then
					sm.PrimaryPart.CFrame = eHRP.CFrame + eHRP.CFrame.LookVector * -1.1
					sm.PrimaryPart.AssemblyLinearVelocity = Vector3.zero
					sm.PrimaryPart.AssemblyAngularVelocity = Vector3.zero
					local hum = char:FindFirstChildWhichIsA("Humanoid")
					if hum and hum.Health > 0 then
						hHRP.CFrame = CFrame.new(sm.PrimaryPart.Position + Vector3.new(0, FarmConfig.Distance, 0))
					end
					if not char:FindFirstChild("FocusCam") then
						local fc = Instance.new("ObjectValue", char)
						fc.Name = "FocusCam"
						fc.Value = sm.PrimaryPart
					elseif char.FocusCam.Value ~= sm.PrimaryPart then
						char.FocusCam.Value = sm.PrimaryPart
					end
					return
				end
			end

			sm.PrimaryPart.CFrame = hHRP.CFrame + Vector3.new(0, 2, 0)
			sm.PrimaryPart.AssemblyLinearVelocity = Vector3.zero
			sm.PrimaryPart.AssemblyAngularVelocity = Vector3.zero
		end, 22, 45)

		local farmStoppedSetupError = false
		local questAttemptStartTick = 0

		while FarmState.Active do
			local questName = FarmState.CurrentQuest == "Auto (Best for Level)" and GetBestQuest() or FarmState.CurrentQuest
			if not questName then
				warn("[LevelFarm] No available quest found for current level.")
				farmStoppedSetupError = true
				notify("NPC Farm", "No quest matches your level. Turn the toggle OFF.", 8, "error")
				break
			end

			local questNPC = workspace:FindFirstChild("Dialogues") and workspace.Dialogues:FindFirstChild(questName)
			if not questNPC then
				warn("[LevelFarm] Quest NPC not found:", questName)
				farmStoppedSetupError = true
				notify("NPC Farm", "Quest NPC missing from map. Turn the toggle OFF.", 8, "error")
				break
			end

			local questData = QuestInfo[questName]
			if not questData then
				warn("[LevelFarm] No quest data for:", questName)
				farmStoppedSetupError = true
				notify("NPC Farm", "Internal quest data missing. Turn the toggle OFF.", 8, "error")
				break
			end

			if FarmState.CompletedQuest then
				pcall(function()
					local hrp = FarmUtil.GetHRP()
					if hrp then
						hrp.AssemblyLinearVelocity = Vector3.zero
						hrp.AssemblyAngularVelocity = Vector3.zero
					end
				end)

				task.wait(0.1)
				pcall(function() TurnInQuest(questNPC) end)
				pcall(function() GetQuest(questNPC) end)
				FarmState.CompletedQuest = false

				if questAttemptStartTick == 0 then
					questAttemptStartTick = tick()
				end

				local lp = Players.LocalPlayer
				local timeout = (questName == "Jotaro") and (tick() + 10) or (tick() + 3.5)
				while lp.PlayerStats.QuestMaxProgress.Value <= 0 and tick() < timeout and FarmState.Active do
					task.wait(0.25)
				end
			end

			if questData.Enemy then
				local lp = Players.LocalPlayer
				while lp.PlayerStats.QuestProgress.Value < lp.PlayerStats.QuestMaxProgress.Value and FarmState.Active do
					local enemy = findAliveQuestEnemy(questData.Enemy)
					if enemy then
						pcall(function() FarmUtil.Kill(enemy) end)
						task.wait(0.25)
					else
						task.wait(0.15)
					end
				end
				FarmState.CompletedQuest = true

			elseif questData.Item then
				while FarmUtil.CountItem(questData.Item) < questData.Amount and FarmState.Active do
					local spawnParent = workspace:FindFirstChild("Item_Spawns") and workspace.Item_Spawns:FindFirstChild("Items")
					if spawnParent then
						for _, item in pairs(spawnParent:GetChildren()) do
							if item.Name == questData.Item then
								FarmUtil.Collect(item)
								break
							end
						end
					end
					task.wait(0.5)
				end
				if FarmUtil.CountItem(questData.Item) >= questData.Amount then
					pcall(function() TurnInQuest(questNPC) end)
					task.wait(1)
				end
				FarmState.CompletedQuest = true
			end

			task.wait(FarmConfig.QuestCheckDelay)
		end

		FarmUtil.CurrentEnemy = nil
		pcall(function() if masterConn then masterConn:Disconnect() end end)
		pcall(function() if connection then connection:Disconnect() end end)

		if farmStoppedSetupError then
			FarmState.Active = false
			FarmState.CurrentQuest = nil
			FarmState.CompletedQuest = false
			clearFocusCam(FarmUtil.GetCharacter())
			if FarmState.OriginalCFrame then
				local h = FarmUtil.GetHRP()
				if h then pcall(function() h.CFrame = FarmState.OriginalCFrame end) end
				FarmState.OriginalCFrame = nil
			end
		end
	end

	local noQuestKillEnabled = false
