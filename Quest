local function ParseQuests()
    local parsed = {}
    local seen = {}
    local dialogues = workspace:FindFirstChild("Dialogues")
    if dialogues then
        for _, v in pairs(dialogues:GetChildren()) do
            local name = v.Name
            local lower = name:lower()
            local isQuest = (lower:find("lvl") or name == "Jotaro")
                and not lower:find("darius")
                and not lower:find("pucci")
                and not lower:find("kars")
            if isQuest and not seen[name] then
                seen[name] = true
                table.insert(parsed, name)
            end
        end
    end
    for questName, _ in pairs(QuestInfo) do
        if dialogues and dialogues:FindFirstChild(questName) and not seen[questName] then
            seen[questName] = true
            table.insert(parsed, questName)
        end
    end
    table.sort(parsed)
    return parsed
end

local ParsedQuests = ParseQuests()
if workspace:FindFirstChild("Dialogues") then
    workspace.Dialogues.ChildAdded:Connect(function(child)
        if not child then return end
        local name = child.Name
        local lower = name:lower()
        local isQuest = (lower:find("lvl") or name == "Jotaro")
            and not lower:find("darius")
            and not lower:find("pucci")
            and not lower:find("kars")
        if isQuest then
            for _, existing in ipairs(ParsedQuests) do
                if existing == name then return end
            end
            table.insert(ParsedQuests, name)
            table.sort(ParsedQuests)
            pcall(function()
                if QuestDropdown and QuestDropdown.Refresh then
                    QuestDropdown:Refresh(ParsedQuests)
                elseif QuestDropdown and QuestDropdown.Set then
                    QuestDropdown:Set(ParsedQuests[1] or "No quests available")
                end
            end)
        end
    end)
end

local function GetBestQuest()
    local player = GetPlayer()
    if not player or not player:FindFirstChild("PlayerStats") or not player.PlayerStats:FindFirstChild("Level") then
        return nil
    end
    local playerLevel = player.PlayerStats.Level.Value
    local bestQuest, highestReq = nil, -1
    for _, questName in pairs(ParsedQuests) do
        local levelReq = tonumber(questName:match("(%d+)"))
        if levelReq and levelReq <= playerLevel and levelReq > highestReq then
            highestReq = levelReq
            bestQuest = questName
        end
    end
    return bestQuest
end

local function GetPlayerLevel()
    local player = GetPlayer()
    if player and player:FindFirstChild("PlayerStats") and player.PlayerStats:FindFirstChild("Level") then
        return player.PlayerStats.Level.Value
    end
    return 0
end

local function GetQuestLevelRequirement(questName)
    if not questName then return 0 end
    local levelReq = tonumber(questName:match("(%d+)"))
    return levelReq or 0
end

local function GetAllNPCs()
    local NPCs = {}
    local seen = {}
    for _, v in pairs(workspace.Living:GetChildren()) do
        if v:FindFirstChild("Spawn") then
            if not seen[v.Name] then
                seen[v.Name] = true
                table.insert(NPCs, v.Name)
            end
        end
    end
    table.sort(NPCs)
    return NPCs
end

local function KillNPC(Enemy)
	if not Enemy then return end
	local enemyHRP = Enemy:FindFirstChild("HumanoidRootPart")
	local enemyHumanoid = Enemy:FindFirstChildWhichIsA("Humanoid")
	local enemyHealth = Enemy:FindFirstChild("Health")
	if not (enemyHRP and enemyHumanoid and enemyHealth) or enemyHealth.Value <= 0 then
		return
	end

	local oldPos
	local hrp = GetHRP()
	if hrp then oldPos = hrp.CFrame end

	local FocusCam = nil

	while Enemy and Enemy.Parent and enemyHRP and enemyHumanoid and enemyHealth and enemyHealth.Value > 0 do
		if not getgenv().NPCFarmEnabled then break end

		enemyHRP = Enemy:FindFirstChild("HumanoidRootPart")
		enemyHumanoid = Enemy:FindFirstChildWhichIsA("Humanoid")
		enemyHealth = Enemy:FindFirstChild("Health")
		if not (enemyHRP and enemyHumanoid and enemyHealth) or enemyHealth.Value <= 0 then
			task.wait(0.215)
			break
		end

		local Character = GetPlayer().Character
		local Humanoid = Character and Character:FindFirstChildWhichIsA("Humanoid")

		if not (Character and Humanoid) or Humanoid.Health <= 0 then
			pcall(function() if FocusCam then FocusCam:Destroy() end FocusCam = nil end)
			pcall(function()
				local Char = GetCharacter()
				if Char and Char:FindFirstChild("FocusCam") then
					Char.FocusCam:Destroy()
				end
			end)

			GetPlayer().CharacterAdded:Wait()
			task.wait(0.5)

			pcall(enableNoclip)

			if getgenv().QuestMethod == "With Stand" and HasStand() then
				local newChar = GetCharacter()
				if newChar and newChar:FindFirstChild("RemoteFunction") then
					pcall(function()
						newChar.RemoteFunction:InvokeServer("ToggleStand", "Toggle")
					end)
				end
			end
			task.wait(0.3)
		else
			local HRP = Character:FindFirstChild("HumanoidRootPart")
			if not HRP then
				task.wait(0.3)
			else
				if getgenv().QuestMethod == "With Stand" then
					if not HasStand() then
						getgenv().QuestMethod = "Without Stand"
						pcall(function()
							if QuestMethodDropdown and QuestMethodDropdown.Set then
								QuestMethodDropdown:Set("Without Stand")
							end
						end)
						Window:Notify("NPC Farm", "No stand detected! Auto-switched to Without Stand.", 3)
					else
						EquipStand()
					end
				else
					EquipStand()
				end

				if Character:FindFirstChild("FocusCam") == nil then
					FocusCam = Instance.new("ObjectValue", Character)
					FocusCam.Name = "FocusCam"
					FocusCam.Value = enemyHRP
				else
					local camVal = Character:FindFirstChild("FocusCam")
					if camVal then camVal.Value = enemyHRP end
				end

				if GetPlayer().PlayerStats and GetPlayer().PlayerStats.Stand and GetPlayer().PlayerStats.Stand.Value ~= "None" and Character:FindFirstChild("StandMorph") and Character.StandMorph.PrimaryPart then
					pcall(function()
						Character.StandMorph.PrimaryPart.CFrame = enemyHRP.CFrame - enemyHRP.CFrame.LookVector * 1.1
						if Character.PrimaryPart and Character.StandMorph.PrimaryPart then
							Character.PrimaryPart.CFrame = Character.StandMorph.PrimaryPart.CFrame + Character.StandMorph.PrimaryPart.CFrame.LookVector * math.random(-3, -2) + Vector3.new(0, -35, 0)
						end
					end)
				else
					if Character.PrimaryPart then
						pcall(function() Character.PrimaryPart.CFrame = enemyHRP.CFrame - enemyHRP.CFrame.LookVector * 2.3 end)
					end
				end

				task.spawn(function() UseMove("m1") end)

				local remote = Character:FindFirstChild("RemoteEvent")
				if remote then
					if game:GetService("CollectionService"):HasTag(Enemy, "Blocking") then
						remote:FireServer("InputBegan", { Input = Enum.KeyCode.R })
					end
					local keys = getgenv().AutoUseStandSkillKeys or {"E"}
					for _, keyName in ipairs(keys) do
						local skillKey = keyName and Enum.KeyCode[keyName] or nil
						if skillKey then
							remote:FireServer("InputBegan", { Input = skillKey })
						end
					end
				end
			end
		end

		task.wait()
	end

	local hrp = GetHRP()
	if hrp then
		if Enemy and Enemy:FindFirstChild("HumanoidRootPart") then
			hrp.CFrame = CFrame.new(Enemy.HumanoidRootPart.Position + Vector3.new(0, 20, 0))
		elseif oldPos then
			hrp.CFrame = oldPos + Vector3.new(0, 15, 0)
		end
		hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		hrp.Velocity = Vector3.new(0, 0, 0)
	end

	task.wait(math.max(0.01, getgenv().QuestDelay or 0.1))

	pcall(function() if FocusCam then FocusCam:Destroy() end end)
	pcall(function()
		local Char = GetCharacter()
		if Char and Char:FindFirstChild("FocusCam") then
			Char.FocusCam:Destroy()
		end
	end)
end
local function GetBestQuestForLevel(currentLevel)
    local bestQuest = nil
    local highestReq = -1
    for _, questName in pairs(ParsedQuests) do
        if questName ~= "No quests available" then
            local levelReq = GetQuestLevelRequirement(questName)
            if levelReq and levelReq <= currentLevel and levelReq > highestReq then
                highestReq = levelReq
                bestQuest = questName
            end
        end
    end
    return bestQuest
end

local function CanTakeQuest(questName)
    local playerLevel = GetPlayerLevel()
    local questLevel = GetQuestLevelRequirement(questName)
    return playerLevel >= questLevel
end

local function GetQuestState()
    local player = GetPlayer()
    if not player or not player:FindFirstChild("PlayerStats") then
        return "none", nil, 0, 0
    end

    local currentQuest = player.PlayerStats:FindFirstChild("CurrentQuest")
    local questProgress = player.PlayerStats:FindFirstChild("QuestProgress")
    local questMax = player.PlayerStats:FindFirstChild("QuestMaxProgress")

    if currentQuest and currentQuest.Value ~= "" and questProgress and questMax then
        local progress = questProgress.Value or 0
        local maxProgress = questMax.Value or 0
        if maxProgress > 0 and progress >= maxProgress then
            return "complete", currentQuest.Value, progress, maxProgress
        end
        return "active", currentQuest.Value, progress, maxProgress
    end

    return "none", nil, 0, 0
end

local function HasActiveQuest()
    local state = GetQuestState()
    return state == "active"
end

local function IsQuestComplete()
    local state = GetQuestState()
    return state == "complete"
end

local function GetCurrentQuestDisplayName()
    local player = GetPlayer()
    if player and player:FindFirstChild("PlayerStats") then
        local currentQuest = player.PlayerStats:FindFirstChild("CurrentQuest")
        if currentQuest and currentQuest.Value ~= "" then
            return currentQuest.Value
        end
    end
    if getgenv().SelectedQuest and getgenv().SelectedQuest ~= "" and getgenv().SelectedQuest ~= "No quests available" then
        return getgenv().SelectedQuest
    end
    return nil
end

local function UpdateQuestStatusLabel()
    local labelText = "No active quest"
    local player = GetPlayer()
    if not player or not player:FindFirstChild("PlayerStats") then
        pcall(function()
            if _G.QuestCurrentQuestLabelObj then
                if _G.QuestCurrentQuestLabelObj.Set then
                    _G.QuestCurrentQuestLabelObj:Set(labelText)
                elseif _G.QuestCurrentQuestLabelObj.Text then
                    _G.QuestCurrentQuestLabelObj.Text = labelText
                end
            end
        end)
        return
    end

    local currentQuest = player.PlayerStats:FindFirstChild("CurrentQuest")
    if not currentQuest or currentQuest.Value == "" then
        pcall(function()
            if _G.QuestCurrentQuestLabelObj then
                if _G.QuestCurrentQuestLabelObj.Set then
                    _G.QuestCurrentQuestLabelObj:Set(labelText)
                elseif _G.QuestCurrentQuestLabelObj.Text then
                    _G.QuestCurrentQuestLabelObj.Text = labelText
                end
            end
        end)
        return
    end

    local questName = currentQuest.Value
    local questProgress = player.PlayerStats:FindFirstChild("QuestProgress")
    local questMax = player.PlayerStats:FindFirstChild("QuestMaxProgress")

    local progress = 0
    local maxProgress = 0
    if questProgress then
        progress = tonumber(questProgress.Value) or 0
    end
    if questMax then
        maxProgress = tonumber(questMax.Value) or 0
    end

    if maxProgress > 0 then
        local remaining = math.max(0, maxProgress - progress)
        if remaining > 0 then
            labelText = questName .. " | " .. tostring(progress) .. "/" .. tostring(maxProgress) .. " (" .. tostring(remaining) .. " left)"
        else
            labelText = questName .. " | " .. tostring(progress) .. "/" .. tostring(maxProgress) .. " | Finished"
        end
    else
        labelText = questName .. " | Progress: " .. tostring(progress)
    end

    pcall(function()
        if _G.QuestCurrentQuestLabelObj then
            if _G.QuestCurrentQuestLabelObj.Set then
                _G.QuestCurrentQuestLabelObj:Set(labelText)
            elseif _G.QuestCurrentQuestLabelObj.Text then
                _G.QuestCurrentQuestLabelObj.Text = labelText
            end
        end
    end)
end

local function IsPlayerReady()
    local player = GetPlayer()
    if not player then return false end
    local character = player.Character
    if not character then return false end
    local humanoid = character:FindFirstChildWhichIsA("Humanoid")
    if not humanoid then return false end
    if humanoid.Health <= 0 then return false end
    if not character:FindFirstChild("HumanoidRootPart") then return false end
    if not character.PrimaryPart then return false end
    return true
end

local function WaitForCharacter(timeout)
    timeout = timeout or 10
    local player = GetPlayer()
    if not player then return false end
    local start = tick()
    while tick() - start < timeout do
        if player.Character then
            local humanoid = player.Character:FindFirstChildWhichIsA("Humanoid")
            if humanoid and humanoid.Health > 0 then
                return true
            end
        end
        task.wait(0.1)
    end
    return false
end

local function clickThroughDialogue()
    local plr = game:GetService("Players").LocalPlayer
    local dialogueGui = plr.PlayerGui:FindFirstChild("DialogueGui")
    local startTime = tick()
    while dialogueGui and dialogueGui.Parent and tick() - startTime < 5 do
        pcall(function()
            local frame = dialogueGui:FindFirstChild("Frame")
            if not frame then return end
            local clickContinue = frame:FindFirstChild("ClickContinue")
            if clickContinue then
                for _, conn in pairs(getconnections(clickContinue.MouseButton1Click)) do
                    conn:Fire()
                end
            end
            local options = frame:FindFirstChild("Options")
            if options then
                local option1 = options:FindFirstChild("Option1")
                if option1 then
                    local textButton = option1:FindFirstChild("TextButton")
                    if textButton then
                        for _, conn in pairs(getconnections(textButton.MouseButton1Click)) do
                            conn:Fire()
                        end
                    end
                end
            end
        end)
        task.wait(0.1)
        dialogueGui = plr.PlayerGui:FindFirstChild("DialogueGui")
    end
end

local function GetQuest(NPC)
    if not NPC then return false end
    local DialogueNameObj = NPC:FindFirstChild("Dialogue")
    local Character = GetCharacter()
    if not DialogueNameObj or not Character or not Character:FindFirstChild("RemoteEvent") then
        return false
    end

    local DialogueName = DialogueNameObj.Value
    local Event = Character:FindFirstChild("RemoteEvent")
    local player = GetPlayer()

    if NPC.Name == "DIO [Lvl. 35+]" then
        pcall(function()
            Event:FireServer("PromptTriggered", game:GetService("ReplicatedStorage"):WaitForChild("Dialogue"):WaitForChild("DIO"))
        end)

        local dlgStart = tick()
        repeat
            task.wait(0.1)
        until player.PlayerGui:FindFirstChild("DialogueGui") or tick() - dlgStart > 3

        clickThroughDialogue()

        getgenv().CompletedQuest = false
        return true
    end

    pcall(function()
        Event:FireServer("DialogueInteracted", {
            ["DialogueName"] = DialogueName,
            ["Speaker"] = NPC.Name
        })
    end)

    for dialogueNum = 1, 8 do
        for optionNum = 1, 3 do
            pcall(function()
                Event:FireServer("EndDialogue", {
                    ["NPC"] = DialogueName,
                    ["Option"] = "Option" .. tostring(optionNum),
                    ["Dialogue"] = "Dialogue" .. tostring(dialogueNum)
                })
            end)
        end
    end

    local specialPatterns = {
        {Dialogue = "Dialogue2", Option = "Option1"},
        {Dialogue = "Dialogue4", Option = "Option1"},
        {Dialogue = "Dialogue6", Option = "Option1"},
        {Dialogue = "Dialogue2", Option = "Option2"},
        {Dialogue = "Dialogue3", Option = "Option1"},
        {Dialogue = "Dialogue5", Option = "Option1"},
    }

    for _, pattern in ipairs(specialPatterns) do
        pcall(function()
            Event:FireServer("EndDialogue", {
                ["NPC"] = DialogueName,
                ["Option"] = pattern.Option,
                ["Dialogue"] = pattern.Dialogue
            })
        end)
    end

    getgenv().CompletedQuest = false
    return true
end

local function TurnInQuest(NPC)
    if not NPC then return false end
    local DialogueNameObj = NPC:FindFirstChild("Dialogue")
    local Character = GetCharacter()
    if not DialogueNameObj or not Character or not Character:FindFirstChild("RemoteEvent") then
        return false
    end

    local DialogueName = DialogueNameObj.Value
    local Event = Character:FindFirstChild("RemoteEvent")
    local plr = game:GetService("Players").LocalPlayer

    if NPC.Name == "DIO [Lvl. 35+]" then
        pcall(function()
            Event:FireServer("PromptTriggered", game:GetService("ReplicatedStorage"):WaitForChild("Dialogue"):WaitForChild("DIO"))
        end)
        local dlgStart = tick()
        repeat
            task.wait(0.1)
        until plr.PlayerGui:FindFirstChild("DialogueGui") or tick() - dlgStart > 3
        clickThroughDialogue()
        task.spawn(function()
            Window:Notify("Quest", "Quest turned in: " .. NPC.Name, 2)
        end)
        return true
    end

    pcall(function()
        Event:FireServer("DialogueInteracted", {
            ["DialogueName"] = DialogueName,
            ["Speaker"] = NPC.Name
        })
    end)

    for dialogueNum = 1, 8 do
        pcall(function()
            Event:FireServer("EndDialogue", {
                ["NPC"] = DialogueName,
                ["Option"] = "Option1",
                ["Dialogue"] = "Dialogue" .. tostring(dialogueNum)
            })
        end)
    end

    task.spawn(function()
        Window:Notify("Quest", "Quest turned in: " .. NPC.Name, 2)
    end)
    return true
end

local function UseMove(Move)
    local Character = GetCharacter()
    if not Character then return end
    if Move:lower() == "m1" or Move:lower() == "m2" then
        if Character:FindFirstChild("RemoteFunction") then
            pcall(function() Character.RemoteFunction:InvokeServer("Attack", Move) end)
        end
    end
end

