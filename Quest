				if remote then
					if game:GetService("CollectionService"):HasTag(Enemy, "Blocking") then
						remote:FireServer("InputBegan", { Input = Enum.KeyCode.R })
					end

					local keys = getgenv().AutoUseStandSkillKeys or {"E"}
					for _, keyName in ipairs(keys) do
						local skillKey = keyName and Enum.KeyCode[keyName] or nil
						if skillKey then
							remote:FireServer("InputBegan", { Input = skillKey })
						end
					end
				end
			end
		end

		task.wait()
	end

	local hrp = GetHRP()
	if hrp then
		if Enemy and Enemy:FindFirstChild("HumanoidRootPart") then
			hrp.CFrame = CFrame.new(Enemy.HumanoidRootPart.Position + Vector3.new(0, 20, 0))
		elseif oldPos then
			hrp.CFrame = oldPos + Vector3.new(0, 15, 0)
		end
		hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		hrp.Velocity = Vector3.new(0, 0, 0)
	end

	task.wait(math.max(0.01, getgenv().QuestDelay or 0.1))

	pcall(function() if FocusCam then FocusCam:Destroy() end end)
	pcall(function()
		local Char = GetCharacter()
		if Char and Char:FindFirstChild("FocusCam") then
			Char.FocusCam:Destroy()
		end
	end)
end
