				Window:Notify("Quest", "Item Farm is running! Disable it first.", 3)
				return
			end
			if getgenv().NPCFarmEnabled then
				Window:Notify("Quest", "NPC Farm is running! Disable it first.", 3)
				return
			end
		end

		getgenv().QuestFarmEnabled = value
		UpdateQuestStatusLabel()

		if value then
			task.spawn(function()
				Window:Notify("Quest", "Quest Farm started!", 3)
			end)
			enableNoclip()

			local player = GetPlayer()
			if player and player:FindFirstChild("PlayerStats") then
				local currentQuest = player.PlayerStats:FindFirstChild("CurrentQuest")
				local questProgress = player.PlayerStats:FindFirstChild("QuestProgress")
				local questMax = player.PlayerStats:FindFirstChild("QuestMaxProgress")

				if currentQuest and currentQuest.Value ~= "" and questProgress and questMax then
					getgenv().SelectedQuest = currentQuest.Value
					FarmState.CurrentQuest = currentQuest.Value
					if questProgress.Value >= questMax.Value then
						getgenv().CompletedQuest = true
						FarmState.CompletedQuest = true
						task.spawn(function()
							Window:Notify("Quest", "Quest complete! Will turn in and get new one.", 3)
						end)
					else
						getgenv().CompletedQuest = false
						FarmState.CompletedQuest = false
						task.spawn(function()
							Window:Notify("Quest", "Resuming quest: " .. currentQuest.Value, 3)
						end)
					end
				else
					getgenv().CompletedQuest = true
					FarmState.CompletedQuest = true
				end
			end

			FarmState.OriginalCFrame = FarmUtil.GetHRP() and FarmUtil.GetHRP().CFrame
			FarmState.Active = true
			task.spawn(FarmLoop)
		else
			FarmState.Active = false
			FarmState.CurrentQuest = nil
			FarmState.CompletedQuest = false
			clearFocusCam(FarmUtil.GetCharacter())
			if FarmState.OriginalCFrame then
				local hrp = FarmUtil.GetHRP()
				if hrp then hrp.CFrame = FarmState.OriginalCFrame end
				FarmState.OriginalCFrame = nil
			end
			Window:Notify("Quest", "Quest Farm stopped!", 3)
			getgenv().NoStandNotified = false
			disableNoclip()
		end
	end)

	local function GetAllNPCs()
		local NPCs = {}
		local seen = {}
		for _, v in pairs(workspace.Living:GetChildren()) do
			if v:FindFirstChild("Spawn") then
				if not seen[v.Name] then
					seen[v.Name] = true
					table.insert(NPCs, v.Name)
				end
			end
		end
		table.sort(NPCs)
		return NPCs
	end

	local NPCList = GetAllNPCs()
	local NPCDropdown = QuestRight:Dropdown("Select NPC", NPCList, NPCList[1] or "", function(selected)
		getgenv().TargetNPC = selected
		noQuestKillTarget = selected
		Window:Notify("Target Set", "Now targeting: " .. selected, 3)
	end)

	workspace.Living.ChildAdded:Connect(function(child)
		if child:FindFirstChild("Spawn") then
			local exists = false
			for _, name in ipairs(NPCDropdown.Options or {}) do
				if name == child.Name then
					exists = true
					break
				end
			end
			if not exists then
				NPCDropdown:Add(child.Name)
			end
		end
	end)

	QuestRight:Toggle("Enable NPC Farm", false, function(state)
		if state then
			if getgenv().normalFarmOn or getgenv().afkFarmOn or getgenv().afkUnderneathFarmOn or getgenv().safePlaceFarmOn then
				Window:Notify("NPC Farm", "Item Farm is running! Disable it first.", 3)
				return
			end
			if getgenv().QuestFarmEnabled then
				Window:Notify("NPC Farm", "Quest Farm is running! Disable it first.", 3)
				return
			end
		end
		getgenv().NPCFarmEnabled = state
		noQuestKillEnabled = state
		if state then
			if getgenv().TargetNPC == "" then
				Window:Notify("Error", "Please select an NPC first!", 4)
				getgenv().NPCFarmEnabled = false
				noQuestKillEnabled = false
				return
			end
			Window:Notify("NPC Farm", "Started farming: " .. getgenv().TargetNPC, 3)
			enableNoclip()
			task.spawn(function()
				while noQuestKillEnabled do
					pcall(function() killNPCNoQuest(noQuestKillTarget) end)
					task.wait(0.2)
				end
				disableNoclip()
				Window:Notify("NPC Farm", "Stopped farming", 3)
			end)
			task.spawn(function()
				while noQuestKillEnabled do
					task.wait(3)
					if not noQuestKillEnabled then break end
					if isHandheldMethod() and not STAND_KEEPALIVE_EXCLUDED[Players.LocalPlayer.PlayerStats.Stand.Value] then
						continue
					end
					local char = Players.LocalPlayer.Character
					if char then
						local ss = char:FindFirstChild("SummonedStand")
						if not (ss and ss.Value) then
							pcall(FarmUtil.EquipStand)
						end
					end
				end
			end)
		else
			noQuestKillEnabled = false
			disableNoclip()
			Window:Notify("NPC Farm", "Stopped farming", 3)
		end
	end)

	local QuestStatusSection = QuestTab:Section("Quest Status", "Right", "activity")
	QuestStatusSection:Paragraph("Live Quest Tracker", Color3.fromRGB(140, 140, 140))
	_G.QuestCurrentQuestLabelObj = QuestStatusSection:Paragraph("No active quest", Color3.fromRGB(100, 255, 100))
	UpdateQuestStatusLabel()

	task.spawn(function()
		local player = GetPlayer()
		if not player then return end
		local stats = player:WaitForChild("PlayerStats")
		local currentQuest = stats:WaitForChild("CurrentQuest")
		local questProgress = stats:WaitForChild("QuestProgress")
		local questMax = stats:WaitForChild("QuestMaxProgress")

		currentQuest.Changed:Connect(function()
			task.wait(0.1)
			pcall(UpdateQuestStatusLabel)
		end)
		questProgress.Changed:Connect(function()
			task.wait(0.05)
			pcall(UpdateQuestStatusLabel)
		end)
		questMax.Changed:Connect(function()
			task.wait(0.05)
			pcall(UpdateQuestStatusLabel)
		end)
	end)

	task.spawn(function()
		while true do
			task.wait(0.5)
			pcall(UpdateQuestStatusLabel)
		end
	end)

	QuestLeft:Button("Show Stats", function()
		local statsText = "{Stand} " .. PlayerStand.Value .. " | {Level} " .. PlayerLevel.Value .. " | {Pity} " .. roundTwo(getPity()) .. " | {Money} $" .. PlayerMoney.Value .. " | {Spec} " .. PlayerSpec.Value
		Window:Notify("Stats", statsText, 10)
	end)

	QuestLeft:Button("Show Active Quests", function()
		local q = getQuests()
		local s = ""
		for name in pairs(q) do s = s .. name .. "\n" end
		if s == "" then s = "No active quests." end
		Window:Notify("Quests", s, 5)
	end)

	QuestLeft:Button("Learn All Stand Skills", function()
		if getgenv().autoPrestigeEnabled or getgenv().autoPrestigeBusy then
			Window:Notify("Skills", "Auto Storyline is running! Stop it first.", 5)
			return
		end
		task.spawn(function()
			learnAllSkills()
			Window:Notify("Skills", "All stand skills learned.", 5)
		end)
	end)

	farmThrottledHeartbeat(function()
		if not (FarmState.Active or noQuestKillEnabled or getgenv().__EldiabloAutoStwActive) then return end
		local char = Players.LocalPlayer.Character
		if not char then return end
		farmEnsureNoclip(char)
	end, 12, 30)

	notify("", "Mob Farm ready.", 4)
end
