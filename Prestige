    local lastNpcKillAt = tick()
    local suspiciousKillWarned = false
    local storyQuestCompletionSent = {}
    local vampireQuestCompletionSent = false
    local questProgressValue = PlayerStats:FindFirstChild("QuestProgress")
    local questMaxProgressValue = PlayerStats:FindFirstChild("QuestMaxProgress")

    local function getQuestProgressText(quests)
        quests = quests or getQuests()
        local progress = (questProgressValue and questProgressValue.Value) or 0
        local maxProgress = (questMaxProgressValue and questMaxProgressValue.Value) or 0
        local progressText = (maxProgress > 0) and (tostring(progress) .. "/" .. tostring(maxProgress)) or nil
        if quests[VAMPIRE_QUEST] then
            if progressText then
                return "Killed " .. progressText .. " vampires"
            end
            return "Killed ?/3 vampires"
        end
        for _, e in ipairs(STORY_NPCS) do
            if quests[e.quest] then
                if progressText then
                    return tostring(e.npc) .. " (" .. progressText .. ")"
                end
                return tostring(e.npc)
            end
        end
        local anyQuest = next(quests)
        if anyQuest then
            if progressText then
                return tostring(anyQuest) .. " (" .. progressText .. ")"
            end
            return tostring(anyQuest)
        end
        return progressText and ("No active quest (" .. progressText .. ")") or "No active quest"
    end

    local function refreshQuestStatus(quests)
        quests = quests or getQuests()
        setStatus(getQuestProgressText(quests))
        return quests
    end

    local function markNpcKill(npcName)
        lastNpcKillAt = tick()
        suspiciousKillWarned = false
        refreshQuestStatus(getQuests())
    end

    local function progressStory()
        if autoPrestigeEnabled and (PlayerStand.Value == "King Crimson" or PlayerStand.Value == "Star Platinum") and PlayerPrestige.Value >= 1 then
            local req = Backpack:FindFirstChild("Requiem Arrow")
            if req then
                local sk = LocalPlayer:FindFirstChild("CharacterSkillTree")
                if not (sk and sk:FindFirstChild("Worthiness V") and sk["Worthiness V"].Value) then
                    pcall(function()
                        for _, skill in ipairs({"Worthiness","Worthiness II","Worthiness III","Worthiness IV","Worthiness V"}) do
                            learnSkill(skill, "Character")
                            task.wait(0.1)
                        end
                    end)
                    task.wait(0.5)
                end
                Window:Notify("Auto Prestige", "Found Requiem Arrow! Attempting to use...", 5)
                local item = req
                getHumanoid():EquipTool(item)
                local inChar = getCharacter():WaitForChild("Requiem Arrow", 3)
                if inChar then
                    repeat
                        pcall(function() inChar:Activate() end)
                        task.wait()
                    until PlayerGui:FindFirstChild("DialogueGui")
                    local dialogueGui = PlayerGui:FindFirstChild("DialogueGui")
                    local startTime = tick()
                    while dialogueGui and dialogueGui.Parent and tick() - startTime < 5 do
                        pcall(function()
                            local frame = dialogueGui:FindFirstChild("Frame")
                            if not frame then return end
                            local clickContinue = frame:FindFirstChild("ClickContinue")
                            if clickContinue then
                                for _, conn in pairs(getconnections(clickContinue.MouseButton1Click)) do
                                    conn:Fire()
                                end
                            end
                            local options = frame:FindFirstChild("Options")
                            if options then
                                local option1 = options:FindFirstChild("Option1")
                                if option1 then
                                    local textButton = option1:FindFirstChild("TextButton")
                                    if textButton then
                                        for _, conn in pairs(getconnections(textButton.MouseButton1Click)) do
                                            conn:Fire()
                                        end
                                    end
                                end
                            end
                        end)
                        task.wait(0.1)
                        dialogueGui = PlayerGui:FindFirstChild("DialogueGui")
                    end
                end
                setStatus("Used Requiem Arrow on " .. PlayerStand.Value .. "!")
                task.wait(6)
            end
        end

        local questsBefore = getQuests()
        local quests = refreshQuestStatus(questsBefore)

        for _, e in ipairs(STORY_NPCS) do
            if not autoPrestigeEnabled then return false end
            if quests[e.quest] then
                setStatus("Killing " .. e.npc)
                while autoPrestigeEnabled and getQuests()[e.quest] do
                    if prestigeKillNPC(e.npc, e.offZ, e.offY) then
                        markNpcKill(e.npc)
                    end
                    local questsNow = getQuests()
                    if questsBefore[e.quest] and not questsNow[e.quest] and not storyQuestCompletionSent[e.quest] then
                        storyQuestCompletionSent[e.quest] = true
                    end
                    if questsNow[e.quest] then
                        storyQuestCompletionSent[e.quest] = false
                    end
                    questsBefore = questsNow
                    refreshQuestStatus(questsNow)
                    if e.npc == "Security Guard" then
                        task.wait(0.8)
                    else
                        task.wait(PRESTIGE_CHAIN_WAIT)
                    end
                end

                if e.npc == "Diavolo" and autoPrestigeEnabled then
                    fireStorylineSweep()
                    task.wait(0.5)
                    fireDialogue("Storyline #14", "Dialogue7", "Option1")
                    task.wait(0.5)
                    local char = LocalPlayer.Character
                    if char then
                        local hum = char:FindFirstChildWhichIsA("Humanoid")
                        if hum then
                            hum.Health = 0
                            task.wait(3)
                        end
                    end
                end
                return true
            end
        end

        local hasVampireQuest = quests[VAMPIRE_QUEST] ~= nil
        local levelUnlocked   = PlayerLevel.Value >= VAMPIRE_LVL_GATE

        if not hasVampireQuest and levelUnlocked then
            setStatus("Checking for remaining story quests...")
            fireStorylineSweep()
            task.wait(1.5)
            local freshQuests = getQuests()
            local gotStoryQuest = false
            for _, e in ipairs(STORY_NPCS) do
                if freshQuests[e.quest] then
                    gotStoryQuest = true
                    break
                end
            end
            if not gotStoryQuest and autoPrestigeEnabled and not getQuests()[VAMPIRE_QUEST] then
                setStatus("Asking William Zeppeli")
                for _ = 1, 6 do
                    if not autoPrestigeEnabled then return false end
                    fireDialogue("William Zeppeli", "Dialogue4", "Option1")
                    task.wait(0.4)
                    if getQuests()[VAMPIRE_QUEST] then break end
                end
            end
        end

        if getQuests()[VAMPIRE_QUEST] then
            setStatus("Killing Vampires")
            while autoPrestigeEnabled and getQuests()[VAMPIRE_QUEST] do
                if prestigeKillNPC("Vampire", VAMPIRE_OFFZ, VAMPIRE_OFFY) then
                    markNpcKill("Vampire")
                end
                local questsNow = getQuests()
                if questsBefore[VAMPIRE_QUEST] and not questsNow[VAMPIRE_QUEST] and not vampireQuestCompletionSent then
                    vampireQuestCompletionSent = true
                end
                if questsNow[VAMPIRE_QUEST] then
                    vampireQuestCompletionSent = false
                end
                questsBefore = questsNow
                refreshQuestStatus(questsNow)
                task.wait(PRESTIGE_VAMPIRE_CHAIN_WAIT)
            end
            return true
        end

        return false
    end

    local function hasAutoPrestigeRuntime()
        local char = LocalPlayer.Character
        if not char or not char.Parent then return false end
        if not char:FindFirstChild("HumanoidRootPart") then return false end
        if not char:FindFirstChild("RemoteEvent") then return false end
        if not char:FindFirstChild("RemoteFunction") then return false end
        local hum = char:FindFirstChildWhichIsA("Humanoid")
        if not hum or hum.Health <= 0 then return false end
        return true
    end

    local function waitForAutoPrestigeRuntime(timeoutSec)
        local deadline = tick() + (timeoutSec or 8)
        repeat
            if hasAutoPrestigeRuntime() then return true end
            task.wait(0.2)
        until tick() > deadline or not autoPrestigeEnabled
        return hasAutoPrestigeRuntime()
    end

    local function runAutoPrestige()
        if autoPrestigeBusy then return end
        autoPrestigeBusy = true
        local runtimeMisses = 0
        local loopErrors = 0

        if isBlacklistedStand(PlayerStand.Value) then
            Window:Notify("Auto Prestige", "Do not use a blacklisted stand: " .. PlayerStand.Value .. ".", 8)
            autoPrestigeEnabled = false
            autoPrestigeBusy = false
            setStatus("Blacklisted stand")
            return
        end
        if not waitForAutoPrestigeRuntime(8) then
            Window:Notify("Auto Prestige", "Character/remotes unavailable. Try again in a moment.", 7)
            autoPrestigeEnabled = false
            autoPrestigeBusy = false
            setStatus("Runtime unavailable")
            return
        end
        task.spawn(learnAllSkills)
        lastNpcKillAt = tick()
        suspiciousKillWarned = false
        refreshQuestStatus(getQuests())

        while autoPrestigeEnabled do
            if PlayerLevel.Value >= 50 then
                Window:Notify("Auto Prestige", "Max level reached.", 7)
                setStatus("Max level (50)")
                autoPrestigeEnabled = false
                break
            end
            if tick() - lastNpcKillAt >= NO_KILL_WARN_TIMEOUT and not suspiciousKillWarned then
                suspiciousKillWarned = true
                Window:Notify("Auto Prestige", "Suspicious activity: no NPC killed within 240 seconds.", 8)
                setStatus("Warning: no NPC kill for 240s")
            end
            if math.floor(tick() * 2) % 4 == 0 then
                refreshQuestStatus(getQuests())
            end
            if not hasAutoPrestigeRuntime() then
                runtimeMisses = runtimeMisses + 1
                setStatus("Recovering runtime (" .. tostring(runtimeMisses) .. "/3)")
                if not waitForAutoPrestigeRuntime(6) and runtimeMisses >= 3 then
                    Window:Notify("Auto Prestige", "Stopped: runtime unavailable after retries.", 7)
                    autoPrestigeEnabled = false
                    break
                end
                task.wait(0.35)
                continue
            end
            runtimeMisses = 0

            if isBlacklistedStand(PlayerStand.Value) then
                Window:Notify("Auto Prestige", "Stopped. Blacklisted stand detected: " .. PlayerStand.Value .. ".", 7)
                autoPrestigeEnabled = false
                break
            end

            local ok, err = pcall(function()
                if canPrestigeNow() then
                    if not firePrestige() then
                        error("prestige flow failed")
                    end
                    if not autoPrestigeEnabled then return end
                end

                local progressed = progressStory()
                if not progressed and autoPrestigeEnabled then
                    setStatus("Claiming storyline")
                    local sweepAttempts = 0
                    local maxSweepAttempts = 15
                    while autoPrestigeEnabled and sweepAttempts < maxSweepAttempts do
                        fireStorylineSweep()
                        task.wait(1)
                        sweepAttempts = sweepAttempts + 1
                        if next(getQuests()) ~= nil then break end
                    end
                    if next(getQuests()) == nil and autoPrestigeEnabled then
                        setStatus("Recovering: no quest assigned")
                        Window:Notify("Auto Prestige", "No quest assigned after storyline sweep. Respawning.", 7)
                        pcall(function() getCharacter().Humanoid.Health = 0 end)
                        waitUntilNewCharAuto(22)
                        task.wait(2)
                    end
                end
            end)
            if not ok then
                loopErrors = loopErrors + 1
                setStatus("Error recovery (" .. tostring(loopErrors) .. "/3)")
                warn("[Auto Prestige] " .. tostring(err))
                if loopErrors >= 3 then
                    Window:Notify("Auto Prestige", "Stopped after repeated runtime errors.", 7)
                    autoPrestigeEnabled = false
                    break
                end
                waitForAutoPrestigeRuntime(6)
                task.wait(0.75)
                continue
            end
            loopErrors = 0
            task.wait(0.3)
        end

        autoPrestigeBusy = false
        if autoPrestigeStatus ~= "Max level (50)" then
            setStatus("Stopped")
        end
    end

