        task.wait()
        pcall(function() getCharacter().Humanoid.Health = 0 end)
        if not waitUntilNewCharAuto(22) then
            setStatus("Respawn timeout after prestige")
            return false
        end
        task.wait(1)
        local deadline = tick() + 8
        repeat
            task.wait(0.5)
            fireStorylineSweep()
        until next(getQuests()) ~= nil or tick() > deadline or not autoPrestigeEnabled
        return true
